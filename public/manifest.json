{
  "manifest_version": 3,
  "name": "TabTidy",
  "version": "0.1.0",
  "description": "Close non-pinned tabs in the current window and keep a timestamped history of each tidy run.",
  "permissions": ["tabs", "storage"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Tidy Tabs with TabTidy",
    "default_icon": {
      "16": "icons/favicon-16x16.png",
      "32": "icons/favicon-32x32.png"
    }
  },
  "options_page": "tabtidy.html",
  "icons": {
    "16": "icons/favicon-16x16.png",
    "32": "icons/favicon-32x32.png",
    "192": "icons/android-chrome-192x192.png",
    "512": "icons/android-chrome-512x512.png"
  }
}
