{
  "manifest_version": 3,
  "name": "TabTidy",
  "version": "0.1.0",
  "description": "Close non-pinned tabs in the current window and keep a dated history of what was tidied.",
  "permissions": ["tabs", "storage"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Tidy Tabs with TabTidy"
  },
  "options_page": "tabtidy.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
